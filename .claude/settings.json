{
  "permissions": {
    "allow": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git clone*)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "network": {
      "allowedDomains": [
        "npm.registry.com",
        "us.i.posthog.com"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/commit-message-validate.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
